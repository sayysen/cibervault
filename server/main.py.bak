            SELECT e.event_id,e.hostname,e.event_type,e.severity,
                   COALESCE(e.risk_score,0) as risk_score,
                   e.mitre_id,e.mitre_tactic,e.rule_name,e.event_time,
                   a.os,a.ip_address
            FROM events e LEFT JOIN agents a ON e.agent_id=a.agent_id
